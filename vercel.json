{
  "redirects": [
    {
      "source": "/en",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/en/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/ro/:path*",
      "destination": "/ro/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/en/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/en/index.html"
    }
  ]
}
