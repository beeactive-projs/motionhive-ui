{
  "name": "motionhive",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build web",
    "build:core": "ng build core",
    "start:admin": "ng serve admin",
    "build:admin": "ng build admin",
    "build:admin:prod": "ng build admin --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "npm run check:reusability && ng test",
    "check:reusability": "node scripts/check-reusability.mjs",
    "extract-i18n": "ng extract-i18n website --output-path projects/website/src/locale && node scripts/xliffmerge.cjs --profile xliffmerge.json"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.1.0",
  "dependencies": {
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/localize": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-server": "21.2.7",
    "@angular/router": "^21.2.6",
    "@angular/service-worker": "^21.2.6",
    "@angular/ssr": "21.2.7",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/postcss": "^4.1.18",
    "chart.js": "^4.5.1",
    "flag-icons": "^7.5.0",
    "libphonenumber-js": "^1.12.42",
    "postcss": "^8.5.6",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.6",
    "@playwright/test": "^1.60.0",
    "@types/jsonwebtoken": "^9.0.10",
    "jsdom": "^27.1.0",
    "jsonwebtoken": "^9.0.3",
    "ng-packagr": "^21.2.2",
    "ngx-i18nsupport": "^0.17.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
