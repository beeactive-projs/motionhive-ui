{
  "name": "motionhive",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build web",
    "build:core": "ng build core",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "extract-i18n": "ng extract-i18n website --output-path projects/website/src/locale && xliffmerge --profile xliffmerge.json"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.1.0",
  "dependencies": {
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/localize": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/postcss": "^4.1.18",
    "chart.js": "^4.5.1",
    "postcss": "^8.5.6",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.6",
    "@types/google.maps": "^3.64.0",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.2.2",
    "ngx-i18nsupport": "^0.17.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
